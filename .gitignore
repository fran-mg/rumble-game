# Metro
.metro-health-check*

# JetBrains / PyCharm
# Ignores all PyCharm caching, layout, modules, and project settings
.idea/

# VS Code
# Keeps shared settings but blocks local workspace states or temporary overrides
.vscode/tasks.json
.vscode/launch.json
.vscode/*.code-workspace
.vscode/.react/
# Explicitly allow your team to share the Tailwind configuration
!.vscode/settings.json

# Debug & Project Summaries
npm-debug.*
yarn-debug.*
yarn-error.*
project_summary.txt
package-list.txt

# macOS
.DS_Store
*.pem

# env file
.env
# Local env files
.env*.local

# TypeScript
*.tsbuildinfo

